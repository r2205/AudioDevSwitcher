<Window
    x:Class="AudioDevSwitcher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AudioDevSwitcher.ViewModels"
    Title="Audio Device Switcher">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Output Devices -->
        <TextBlock Grid.Row="0" Text="Output Devices" Style="{StaticResource SubtitleTextBlockStyle}"/>

        <ListView Grid.Row="1"
                  x:Name="OutputList"
                  ItemsSource="{x:Bind ViewModel.OutputDevices}"
                  SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:AudioDeviceViewModel">
                    <Grid Padding="8,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0" Glyph="&#xE7F5;" FontSize="20"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <FontIcon Grid.Column="2" Glyph="&#xE73E;" FontSize="16"
                                  Foreground="{ThemeResource SystemAccentColor}"
                                  Visibility="{x:Bind vm:AudioDeviceViewModel.BoolToVisibility(IsDefault), Mode=OneWay}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Input Devices -->
        <TextBlock Grid.Row="2" Text="Input Devices" Style="{StaticResource SubtitleTextBlockStyle}"/>

        <ListView Grid.Row="3"
                  x:Name="InputList"
                  ItemsSource="{x:Bind ViewModel.InputDevices}"
                  SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:AudioDeviceViewModel">
                    <Grid Padding="8,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0" Glyph="&#xE720;" FontSize="20"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <FontIcon Grid.Column="2" Glyph="&#xE73E;" FontSize="16"
                                  Foreground="{ThemeResource SystemAccentColor}"
                                  Visibility="{x:Bind vm:AudioDeviceViewModel.BoolToVisibility(IsDefault), Mode=OneWay}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Bottom toolbar -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Refresh" Command="{x:Bind ViewModel.RefreshDevicesCommand}"/>
        </StackPanel>
    </Grid>

</Window>
